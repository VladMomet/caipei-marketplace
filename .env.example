# ====================================================================
# CaiPei Marketplace — environment configuration
#
# Деплой: Vercel (frontend + serverless) + Neon (managed Postgres)
#
# ЛОКАЛЬНО:
#   1. cp .env.example .env.local
#   2. подставьте реальные значения для DATABASE_URL и AUTH_SECRET
#   3. npm run dev
#
# НА VERCEL:
#   Project → Settings → Environment Variables → добавить каждую.
# ====================================================================

# === БАЗА ДАННЫХ (Neon Postgres) =====================================
# Neon: https://neon.tech — Frankfurt (eu-central-1) ближе всего к RU-клиентам.
# Создаёте проект → копируете connection string из консоли.
# Формат: postgresql://user:pass@ep-xxx-xxx.eu-central-1.aws.neon.tech/caipei?sslmode=require
DATABASE_URL=postgresql://USER:PASS@ep-xxx-xxx.eu-central-1.aws.neon.tech/caipei?sslmode=require

# === Auth.js =========================================================
# Сгенерируйте: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-random-string-at-least-32-chars-long

# Локально: http://localhost:3000
# На Vercel — задаётся автоматически из VERCEL_URL,
# но можно явно прописать ваш домен: https://caipei.ru
AUTH_URL=http://localhost:3000

# === Telegram-бот ====================================================
# Тестовый бот для разработки. ОБЯЗАТЕЛЬНО заменить перед публикацией:
#   @BotFather → /revoke → новый токен → вставить в Vercel Env Vars.
#
# Чат менеджеров уже создан, бот в нём — ID ниже.
TELEGRAM_BOT_TOKEN=8990722243:AAGRIy4tqg6c-sTwOFoIY-pdBGfngQaOuxY
TELEGRAM_MANAGER_CHAT_ID=-1003948541365

# Случайный секрет, которым Telegram подписывает webhook-запросы.
# Используется в /api/telegram/webhook для отсечки чужих обращений.
# Сгенерируйте: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=replace-with-random-hex

# === Импорт товаров (только для scripts) =============================
PRODUCTS_XLSX_PATH=./data/nap.xlsx

# === Яндекс.Метрика (опционально) ====================================
NEXT_PUBLIC_YANDEX_METRICA_ID=

# === Среда ===========================================================
NODE_ENV=development
