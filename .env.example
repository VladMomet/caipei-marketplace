# ====================================================================
# CaiPei Marketplace — environment configuration
#
# Один код обслуживает 3 сайта:
#   SITE_TIER=lite      → caipei-lite.ru      (× 1.0)
#   SITE_TIER=standard  → caipei.ru           (× 1.5)
#   SITE_TIER=prestige  → caipei-premium.ru   (× 2.5)
#
# На VPS Yandex Cloud под PM2 запускаются 3 процесса на портах 3000/3001/3002
# с разным SITE_TIER — все они делят одну БД PostgreSQL, стоящую на той же VM.
#
# ЛОКАЛЬНО:
#   1. cp .env.example .env.local
#   2. подставьте свои значения
#   3. npm run dev
# ====================================================================

# === Тариф сайта (что запускаем) =====================================
# Значения: lite | standard | prestige
# Для локальной разработки — обычно standard (текущий caipei.ru).
SITE_TIER=standard

# Публичная копия для клиента — Next.js прокинет это в клиентский бандл
# автоматически (все переменные с префиксом NEXT_PUBLIC_ доступны в браузере).
# ДОЛЖНА совпадать с SITE_TIER.
NEXT_PUBLIC_SITE_TIER=standard

# === БАЗА ДАННЫХ (одна на 3 сайта) ==================================
# На VPS Yandex Cloud — Postgres установлен локально, значит:
#   DATABASE_URL=postgresql://caipei:пароль@localhost:5432/caipei
#
# Для локальной разработки под Docker:
#   docker run -d --name pg -e POSTGRES_PASSWORD=pass -p 5432:5432 postgres:16
#   DATABASE_URL=postgresql://postgres:pass@localhost:5432/caipei
DATABASE_URL=postgresql://caipei:password@localhost:5432/caipei

# === Auth.js =========================================================
# Сгенерируйте: openssl rand -base64 32
# ⚠️ На всех 3 инстансах должен быть ОДИН И ТОТ ЖЕ секрет,
# иначе сессии не будут работать даже в рамках одного домена при рестарте.
AUTH_SECRET=replace-me-with-a-random-string-at-least-32-chars-long

# Публичный URL текущего инстанса. Для локальной разработки:
#   AUTH_URL=http://localhost:3000
# В продакшене на каждом инстансе — свой:
#   AUTH_URL=https://caipei-lite.ru      (SITE_TIER=lite)
#   AUTH_URL=https://caipei.ru           (SITE_TIER=standard)
#   AUTH_URL=https://caipei-premium.ru   (SITE_TIER=prestige)
AUTH_URL=http://localhost:3000

# === Telegram-бот (общий на 3 сайта) =================================
# Один бот, один общий чат менеджеров.
# В каждом уведомлении первой строкой будет метка [LITE] / [STANDARD] / [PRESTIGE].
TELEGRAM_BOT_TOKEN=8990722243:AAGRIy4tqg6c-sTwOFoIY-pdBGfngQaOuxY
TELEGRAM_MANAGER_CHAT_ID=-1003948541365

# Случайный секрет, которым Telegram подписывает webhook-запросы.
# Сгенерируйте: openssl rand -hex 24
# Используется в /api/telegram/webhook. Одинаковый на 3 инстансах — вебхук будет
# зарегистрирован только на одном домене (например, caipei.ru), остальные два
# просто не получают callback'ов Telegram.
TELEGRAM_WEBHOOK_SECRET=replace-with-random-hex

# === Импорт товаров (только для scripts) =============================
PRODUCTS_XLSX_PATH=./data/nap.xlsx

# === Яндекс.Метрика (опционально) ====================================
# Можно завести отдельные счётчики на каждый домен.
NEXT_PUBLIC_YANDEX_METRICA_ID=

# === Среда ===========================================================
NODE_ENV=development
